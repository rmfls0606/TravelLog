rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /cities/{cityId} {
      allow read: if true;

      allow update: if
        request.resource.data.diff(resource.data).changedKeys().hasOnly(["popularityCount"]) &&
        request.resource.data.popularityCount is int &&
        request.resource.data.popularityCount == resource.data.popularityCount + 1;
    }
  }
}
